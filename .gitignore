# macOS
.DS_Store

# Xcode / build output
build/
DerivedData/
*.xcuserstate
xcuserdata/
*.xcscmblueprint
*.moved-aside

# XcodeGen: the .xcodeproj is generated from project.yml (source of truth)
*.xcodeproj

# Swift Package Manager
.build/
.swiftpm/

# Local-only code-signing config (never commit the signing identity / team)
Signing.xcconfig
*.local.xcconfig

# Local-only release env and staging output (never commit signing inputs or artifacts)
.env.local
release/

# Sparkle / update signing keys (must stay local)
.sparkle/
*.private-key
eddsa_priv*
dsa_priv.pem
