# Copy this file to `.env.local` and fill in your values.
# `.env.local` is git-ignored; never commit it.
#
# Loaded automatically by `./scripts/release.sh` and by XcodeGen before
# local Debug/Release project generation.

# macOS code-signing identity used to sign the release app bundle.
# Find yours with: security find-identity -p codesigning -v
# `PEEKBAR_SIGNING_IDENTITY` is also accepted, but this matches ai-buddy.
APPLE_SIGNING_IDENTITY="Apple Development: you@example.com (XXXXXXXXXX)"

# Sparkle EdDSA private key used to sign update archives.
# Generate/store this outside git. Lose it = existing installs cannot trust updates.
SPARKLE_PRIVATE_KEY_PATH="$HOME/.sparkle/peekbar-ed25519-private-key"

# GitHub owner/repo used for tags, release assets, and appcast download URLs.
GITHUB_REPOSITORY="imekachi/peek-bar"
